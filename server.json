{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.snowmanjy/hippodid-mcp-server",
  "title": "HippoDid MCP Server",
  "description": "Persistent, structured cloud memory for AI agents. BYOK — bring your own AI key.",
  "repository": {
    "url": "https://github.com/SameThoughts/hippodid-mcp-server",
    "source": "github"
  },
  "websiteUrl": "https://hippodid.com",
  "version": "2.0.0",
  "packages": [
    {
      "registryType": "mcpb",
      "identifier": "https://github.com/SameThoughts/hippodid-mcp-server/releases/download/v2.0.0/hippodid-mcp-server-2.0.0.jar",
      "version": "2.0.0",
      "fileSha256": "7262570496758dad65af4cd9aac946fe0a2c9b67dc1bb6c3c7b842f3bdd12836",
      "transport": {
        "type": "stdio"
      },
      "runtimeArguments": [
        {
          "type": "positional",
          "value": "-jar"
        },
        {
          "type": "positional",
          "value": "hippodid-mcp-server-2.0.0.jar"
        }
      ],
      "environmentVariables": [
        {
          "name": "HIPPODID_API_KEY",
          "description": "Your HippoDid API key. Get one at https://app.hippodid.com/settings/api-keys",
          "required": true
        },
        {
          "name": "HIPPODID_CHARACTER_ID",
          "description": "Default character UUID for background sync",
          "required": false
        },
        {
          "name": "HIPPODID_BASE_URL",
          "description": "API base URL (default: https://api.hippodid.com)",
          "required": false
        },
        {
          "name": "HIPPODID_MCP_MODE",
          "description": "Transport mode: stdio (default) or sse",
          "required": false
        },
        {
          "name": "HIPPODID_MCP_SSE_PORT",
          "description": "HTTP port for SSE mode (default: 8090)",
          "required": false
        }
      ]
    }
  ]
}
