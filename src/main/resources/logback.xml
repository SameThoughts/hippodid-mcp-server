<?xml version="1.0" encoding="UTF-8"?>
<!--
  MCP stdio transport: stdout is reserved for JSON-RPC protocol messages.
  ALL logging MUST go to stderr — otherwise log lines corrupt the protocol.
-->
<configuration>
    <appender name="STDERR" class="ch.qos.logback.core.ConsoleAppender">
        <target>System.err</target>
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="STDERR" />
    </root>
</configuration>
